<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.LoginPage"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="28,48,28,32" Spacing="20" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,8">
                <Image Source="opennas_logo.svg"
                       WidthRequest="72"
                       HeightRequest="72"
                       HorizontalOptions="Center"
                       SemanticProperties.Description="OpenNas" />
                <Label Text="OpenNas"
                       Style="{StaticResource PageTitle}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="ServerLabel"
                           Style="{StaticResource Caption}"
                           LineBreakMode="TailTruncation" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="用户名" Style="{StaticResource MicroCaption}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="usernameEntry"
                                   Placeholder="DSM 用户名"
                                   ReturnType="Next"
                                   Completed="OnUsernameCompleted" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="密码" Style="{StaticResource MicroCaption}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="2">
                                <Entry x:Name="passwordEntry"
                                       Grid.Column="0"
                                       Placeholder="密码"
                                       IsPassword="True"
                                       ReturnType="Done"
                                       Completed="OnEntryCompleted" />
                                <ImageButton x:Name="TogglePasswordButton"
                                             Grid.Column="1"
                                             Source="eye_open.svg"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             Padding="8"
                                             MinimumHeightRequest="40"
                                             MinimumWidthRequest="40"
                                             BackgroundColor="Transparent"
                                             BorderWidth="0"
                                             VerticalOptions="Center"
                                             SemanticProperties.Hint="显示密码"
                                             Clicked="OnTogglePasswordClicked" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator x:Name="LoginIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                                       HorizontalOptions="Center" />

                    <Button x:Name="LoginButton"
                            Text="登录"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnLoginButtonClicked" />

                    <Button x:Name="SettingsButton"
                            Text="连接设置"
                            Style="{StaticResource OutlineButton}"
                            Clicked="OnConnectionSettingsClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
