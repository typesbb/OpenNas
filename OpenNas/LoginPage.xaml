<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.LoginPage"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="28,48,28,32" Spacing="20" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,8">
                <Image Source="opennas_logo.svg"
                       WidthRequest="72"
                       HeightRequest="72"
                       HorizontalOptions="Center"
                       SemanticProperties.Description="OpenNas" />
                <Label Text="OpenNas"
                       Style="{StaticResource PageTitle}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Connection error banner — shown prominently when config loading fails -->
            <Border x:Name="ConnectionErrorBanner"
                    IsVisible="False"
                    BackgroundColor="{AppThemeBinding Light=#FFEEE0, Dark=#4A2020}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F5A623, Dark=#FF6B6B}"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="ConnectionErrorTitle"
                           Text="加载连接配置失败"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#D14524, Dark=#FF8C8C}"
                           HorizontalOptions="Center" />
                    <Label x:Name="ConnectionErrorDetail"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#8B4513, Dark=#FFB8B8}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                    <Button x:Name="GoToSettingsFromErrorButton"
                            Text="前往配置"
                            FontSize="13"
                            Padding="16,6"
                            HorizontalOptions="Center"
                            Margin="0,4,0,0"
                            BackgroundColor="{AppThemeBinding Light=#D14524, Dark=#FF6B6B}"
                            TextColor="White"
                            CornerRadius="6"
                            BorderWidth="0"
                            Clicked="OnGoToSettingsClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Normal connection info label -->
            <Label x:Name="ServerLabel"
                   Style="{StaticResource Caption}"
                   LineBreakMode="TailTruncation"
                   HorizontalTextAlignment="Center" />

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="用户名" Style="{StaticResource MicroCaption}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="usernameEntry"
                                   Placeholder="DSM 用户名"
                                   ReturnType="Next"
                                   Completed="OnUsernameCompleted" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="密码" Style="{StaticResource MicroCaption}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="2">
                                <Entry x:Name="passwordEntry"
                                       Grid.Column="0"
                                       Placeholder="密码"
                                       IsPassword="True"
                                       ReturnType="Done"
                                       Completed="OnEntryCompleted" />
                                <ImageButton x:Name="TogglePasswordButton"
                                             Grid.Column="1"
                                             Source="eye_open.svg"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             Padding="8"
                                             MinimumHeightRequest="40"
                                             MinimumWidthRequest="40"
                                             BackgroundColor="Transparent"
                                             BorderWidth="0"
                                             VerticalOptions="Center"
                                             SemanticProperties.Hint="显示密码"
                                             Clicked="OnTogglePasswordClicked" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator x:Name="LoginIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                                       HorizontalOptions="Center" />

                    <Button x:Name="LoginButton"
                            Text="登录"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnLoginButtonClicked" />

                    <Button x:Name="SettingsButton"
                            Text="连接设置"
                            Style="{StaticResource OutlineButton}"
                            Clicked="OnConnectionSettingsClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
