<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.LoginPage"
             Title="登录"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="28,48,28,32" Spacing="20" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,8">
                <Border WidthRequest="72"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BrandPrimarySoft}, Dark={StaticResource BrandPrimarySoftDark}}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label Text="ON"
                           FontFamily="OpenSansSemibold"
                           FontSize="28"
                           TextColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="OpenNas"
                       Style="{StaticResource PageTitle}"
                       HorizontalOptions="Center" />
                <Label Text="连接你的 Synology NAS，管理相册与备份"
                       Style="{StaticResource Caption}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="ServerLabel"
                           Style="{StaticResource Caption}"
                           LineBreakMode="TailTruncation" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="用户名" Style="{StaticResource MicroCaption}" />
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="usernameEntry"
                                   Placeholder="DSM 用户名"
                                   ReturnType="Next"
                                   Completed="OnUsernameCompleted" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="密码" Style="{StaticResource MicroCaption}" VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    x:Name="TogglePasswordButton"
                                    Text="显示"
                                    Style="{StaticResource OutlineButton}"
                                    Padding="10,4"
                                    MinimumHeightRequest="32"
                                    FontSize="12"
                                    Clicked="OnTogglePasswordClicked" />
                        </Grid>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="passwordEntry"
                                   Placeholder="密码"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   Completed="OnEntryCompleted" />
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator x:Name="LoginIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                                       HorizontalOptions="Center" />

                    <Button x:Name="LoginButton"
                            Text="登录"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnLoginButtonClicked" />

                    <Button x:Name="SettingsButton"
                            Text="连接设置"
                            Style="{StaticResource OutlineButton}"
                            Clicked="OnConnectionSettingsClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
