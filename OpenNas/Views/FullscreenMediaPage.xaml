<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.FullscreenMediaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    <Grid>
        <Grid x:Name="MediaHost" />
        <Grid x:Name="ChromeLayer"
              InputTransparent="True"
              CascadeInputTransparent="False"
              VerticalOptions="Start"
              Padding="8,44,8,0"
              ColumnDefinitions="Auto,*,Auto">
            <ImageButton x:Name="BackButton"
                         Grid.Column="0"
                         Source="icon_back.png"
                         BackgroundColor="#44FFFFFF"
                         CornerRadius="22"
                         WidthRequest="44"
                         HeightRequest="44"
                         Padding="10"
                         Clicked="OnBackClicked" />
            <ImageButton x:Name="RotateButton"
                         Grid.Column="2"
                         Source="icon_rotate.png"
                         BackgroundColor="Transparent"
                         WidthRequest="44"
                         HeightRequest="44"
                         Padding="8"
                         Clicked="OnRotateClicked" />
        </Grid>
    </Grid>
</ContentPage>
