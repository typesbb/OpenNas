<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.ConnectionSettingsPage"
             Title="连接设置">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Label Text="NAS 地址" Style="{StaticResource SectionTitle}" />

            <CollectionView x:Name="ProfilesView"
                            SelectionMode="Single"
                            SelectionChanged="OnProfileSelected"
                            HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                <Label Text="{Binding BaseUrl}" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="编辑配置" Style="{StaticResource SectionTitle}" />
                    <Entry x:Name="NameEntry" Placeholder="显示名称" />
                    <Entry x:Name="UrlEntry" Placeholder="https://192.168.x.x:5001" Keyboard="Url" />
                    <Picker x:Name="KindPicker" Title="网络类型" />
                    <Button Text="保存/更新配置"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnSaveProfileClicked" />
                    <Button Text="设为当前连接"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnSetActiveClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
