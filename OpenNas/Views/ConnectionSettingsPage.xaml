<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.ConnectionSettingsPage"
             Title="连接与账号">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="NAS 地址配置" FontSize="18" FontAttributes="Bold" />
            <CollectionView x:Name="ProfilesView" SelectionMode="Single" SelectionChanged="OnProfileSelected" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,4" Stroke="{AppThemeBinding Light=#DDD, Dark=#555}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                <Label Text="{Binding BaseUrl}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Entry x:Name="NameEntry" Placeholder="显示名称" />
            <Entry x:Name="UrlEntry" Placeholder="https://192.168.x.x:5001" Keyboard="Url" />
            <Picker x:Name="KindPicker" Title="网络类型" />
            <Button Text="保存/更新配置" Clicked="OnSaveProfileClicked" />
            <Button Text="设为当前连接" Clicked="OnSetActiveClicked" />
            <Label Text="备份策略" FontSize="16" FontAttributes="Bold" />
            <HorizontalStackLayout>
                <Switch x:Name="WifiOnlySwitch" Toggled="OnWifiOnlyToggled" />
                <Label Text="仅 Wi-Fi 时备份" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout>
                <Switch x:Name="ConfirmDeleteSwitch" Toggled="OnConfirmDeleteToggled" />
                <Label Text="删除本地前需已确认风险" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Button Text="我已了解删除风险" Clicked="OnAckDeleteRiskClicked" />
            <Button Text="重新登录" Clicked="OnReloginClicked" TextColor="DarkOrange" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
