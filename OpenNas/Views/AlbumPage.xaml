<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.AlbumPage"
             Title="相册">

    <ScrollView>
        <FlexLayout BindableLayout.ItemsSource="{Binding}" Wrap="Wrap" JustifyContent="Start" AlignItems="Center" AlignContent="Start">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="2" Margin="2" BackgroundColor="Transparent" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAlbumTapped"/>
                        </Frame.GestureRecognizers>
                        <StackLayout>
                            <Image Aspect="AspectFill" HeightRequest="100" WidthRequest="100" HandlerChanged="OnImageHandlerChanged"/>
                            <Label Text="{Binding Name}" FontSize="Micro" HorizontalOptions="Center" VerticalOptions="CenterAndExpand"/>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>
    </ScrollView>

    <!--<RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
        <CollectionView ItemsSource="{Binding}" ItemsLayout="VerticalGrid, 3" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" SelectionMode="Single" SelectionChanged="OnAlbumSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="10" BackgroundColor="Transparent" BorderColor="Transparent">
                        <StackLayout>
                            <Image Aspect="AspectFill" HeightRequest="100" WidthRequest="100" HandlerChanged="OnImageHandlerChanged"/>
                            <Label Text="{Binding Name}" FontSize="Micro" HorizontalOptions="Center" VerticalOptions="CenterAndExpand"/>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>-->
</ContentPage>