<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             xmlns:vm="clr-namespace:OpenNas.ViewModels"
             x:Class="OpenNas.Views.TasksPage"
             Title="任务">

    <Grid RowDefinitions="Auto,*" Padding="16,12" RowSpacing="10">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
            <Label Text="相册备份"
                   Style="{StaticResource SectionTitle}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="+"
                    Style="{StaticResource CompactOutlineButton}"
                    WidthRequest="34"
                    Padding="0"
                    Clicked="OnAddRuleClicked" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Rules}"
                        SelectionMode="None"
                        ItemsUpdatingScrollMode="KeepItemsInView">
            <CollectionView.EmptyView>
                <controls:EmptyStateView Title="还没有规则"
                                         Message="点 + 添加本机相册到 NAS 的备份映射。"
                                         IconText="📁" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BackupRuleItemViewModel">
                    <Border Style="{StaticResource RuleRowBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnRuleTapped" />
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Label Text="{Binding SummaryLine}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding MetaLine}"
                                           Style="{StaticResource MicroCaption}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding ProgressPercentText}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       VerticalOptions="Center"
                                       MinimumWidthRequest="72"
                                       HorizontalTextAlignment="End" />
                                <Button Grid.Column="2"
                                        Text="重试"
                                        Style="{StaticResource CompactOutlineButton}"
                                        Padding="8,4"
                                        FontSize="12"
                                        IsVisible="{Binding ShowRetry}"
                                        VerticalOptions="Center"
                                        Clicked="OnRuleRetryClicked" />
                                <Button Grid.Column="3"
                                        Text="{Binding ActionIcon}"
                                        Style="{StaticResource IconCircleButton}"
                                        VerticalOptions="Center"
                                        Clicked="OnRuleActionClicked" />
                            </Grid>
                            <ProgressBar Progress="{Binding Progress}"
                                         Style="{StaticResource ThinProgressBar}"
                                         IsVisible="{Binding ShowProgress}" />
                            <VerticalStackLayout IsVisible="{Binding ShowQueueItems}"
                                                 Spacing="4">
                                <controls:BackupQueueRowView BindingContext="{Binding QueueRow0}" />
                                <controls:BackupQueueRowView BindingContext="{Binding QueueRow1}" />
                                <controls:BackupQueueRowView BindingContext="{Binding QueueRow2}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
