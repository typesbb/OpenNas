<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OpenNas.Views"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="OpenNas.Views.AlbumsPage"
             Title="相册"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground}, Dark={StaticResource AppBackgroundDark}}">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Padding="12,8,8,4" MinimumHeightRequest="44">
            <Border x:Name="ViewTitleButton"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="12,6"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource BrandPrimarySoft}, Dark={StaticResource BrandPrimarySoftDark}}">
                <Border.StrokeShape>
                    <shapes:RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnViewTitleClicked" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6"
                                       VerticalOptions="Center">
                    <Label x:Name="ViewTitleLabel"
                           Text="探索"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource BrandPrimaryDark}, Dark={StaticResource BrandPrimaryLight}}" />
                    <Label Text="▼"
                           FontSize="14"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           Margin="0,1,0,0"
                           TextColor="{AppThemeBinding Light={StaticResource BrandPrimaryDark}, Dark={StaticResource BrandPrimaryLight}}" />
                </HorizontalStackLayout>
            </Border>

            <HorizontalStackLayout HorizontalOptions="End"
                                   VerticalOptions="Center"
                                   Spacing="4">
                <Button x:Name="SortButton"
                        Text="⇅"
                        IsVisible="False"
                        Style="{StaticResource ToolbarIconButton}"
                        SemanticProperties.Hint="排序"
                        Clicked="OnSortClicked" />
                <Button x:Name="AddButton"
                        Text="+"
                        FontSize="26"
                        Style="{StaticResource ToolbarIconButton}"
                        SemanticProperties.Hint="新建相册"
                        Clicked="OnAddClicked" />
            </HorizontalStackLayout>
        </Grid>

        <Grid x:Name="ContentHost" Grid.Row="1">
            <views:ExploreView x:Name="ExploreContent" IsVisible="True" />
            <views:NasAlbumsView x:Name="AlbumsContent" IsVisible="False" />
            <views:TimelineView x:Name="TimelineContent" IsVisible="False" />

            <controls:PhotosLibrarySpaceBar x:Name="SpaceBar"
                                            ZIndex="10"
                                            HorizontalOptions="Center"
                                            VerticalOptions="End" />
        </Grid>

        <controls:DropdownMenuOverlay x:Name="Dropdown"
                                      Grid.Row="0"
                                      Grid.RowSpan="2"
                                      ZIndex="99"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Fill" />
    </Grid>
</ContentPage>
