<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:foto="clr-namespace:NSynology.Foto;assembly=NSynology"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             xmlns:behaviors="clr-namespace:OpenNas.Behaviors"
             x:Class="OpenNas.Views.NasAlbumsView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label x:Name="AlbumCountLabel"
               Grid.Row="0"
               FontSize="12"
               Margin="4,0,4,6"
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />

        <RefreshView x:Name="AlbumsRefreshView"
                     Grid.Row="1"
                     RefreshColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}">
            <CollectionView x:Name="AlbumsView"
                            SelectionMode="None"
                            ItemsLayout="VerticalGrid, 3">
                <CollectionView.EmptyView>
                    <controls:EmptyStateView Title="暂无相册"
                                             Message="下拉刷新或点右上角 + 新建相册。"
                                             IconText="🖼" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="foto:Album">
                        <VerticalStackLayout Padding="6,10" Spacing="6">
                            <VerticalStackLayout.Behaviors>
                                <behaviors:LongPressBehavior />
                            </VerticalStackLayout.Behaviors>
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAlbumTapped" />
                            </VerticalStackLayout.GestureRecognizers>
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Image Aspect="AspectFill"
                                       HeightRequest="112"
                                       HandlerChanged="OnThumbHandlerChanged" />
                            </Border>
                            <Label Text="{Binding Name}"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="{Binding ItemCount}"
                                   Style="{StaticResource MicroCaption}"
                                   Margin="0,-4,0,0" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator x:Name="BusyIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <controls:DropdownMenuOverlay x:Name="Dropdown" Grid.Row="0" Grid.RowSpan="2" ZIndex="99" />
    </Grid>
</ContentView>