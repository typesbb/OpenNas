<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:foto="clr-namespace:NSynology.Foto;assembly=NSynology"
             x:Class="OpenNas.Views.NasAlbumsView">
    <Grid RowDefinitions="Auto,*" Padding="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <Label x:Name="StatusLabel"
                   Text="正在加载…"
                   FontSize="13"
                   TextColor="Gray"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
            <Button Grid.Column="1" Text="刷新" Clicked="OnRefreshClicked" Padding="12,6" />
            <ActivityIndicator x:Name="BusyIndicator"
                               Grid.ColumnSpan="2"
                               IsRunning="False"
                               IsVisible="False"
                               HorizontalOptions="End"
                               VerticalOptions="Center" />
        </Grid>
        <CollectionView x:Name="AlbumsView"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="OnAlbumSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="foto:Album">
                    <Grid ColumnDefinitions="72,*" Padding="8,6" ColumnSpacing="12">
                        <Image HeightRequest="72"
                               WidthRequest="72"
                               Aspect="AspectFill"
                               BackgroundColor="#EEEEEE"
                               HandlerChanged="OnThumbHandlerChanged" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding ItemCount, StringFormat='{0} 项'}"
                                   FontSize="12"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>
