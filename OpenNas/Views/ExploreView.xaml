<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

             xmlns:controls="clr-namespace:OpenNas.Controls"

             x:Class="OpenNas.Views.ExploreView">

    <Grid>

        <RefreshView x:Name="RefreshHost"

                     RefreshColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}">

            <ScrollView>

                <VerticalStackLayout x:Name="SectionsHost" Padding="12,0,12,24" Spacing="20" />

            </ScrollView>

        </RefreshView>



        <ActivityIndicator x:Name="BusyIndicator"

                           IsRunning="False"

                           IsVisible="False"

                           Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"

                           HorizontalOptions="Center"

                           VerticalOptions="Center" />



        <controls:DropdownMenuOverlay x:Name="Dropdown"
                                      ZIndex="99"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Fill" />

    </Grid>

</ContentView>


