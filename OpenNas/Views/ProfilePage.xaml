<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             x:Class="OpenNas.Views.ProfilePage"
             Title="我的">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <controls:ConnectionBanner x:Name="ConnectionBanner" />

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="NAS 信息" Style="{StaticResource SectionTitle}" />
                    <Label x:Name="ProfileNameLabel" FontSize="15" />
                    <Label x:Name="ProfileUrlLabel" Style="{StaticResource Caption}" LineBreakMode="TailTruncation" />
                    <Label x:Name="LoginStateLabel" Style="{StaticResource Caption}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="设置" Style="{StaticResource MicroCaption}" Margin="4,0,0,0" />

            <Border Style="{StaticResource SettingRowBorder}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnConnectionClicked" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="连接与账号设置" VerticalOptions="Center" FontSize="15" />
                    <Label Grid.Column="1" Text="›" FontSize="20"
                           TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingRowBorder}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReloginClicked" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="重新登录" VerticalOptions="Center" FontSize="15" />
                    <Label Grid.Column="1" Text="›" FontSize="20"
                           TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <Button Text="退出登录"
                    Style="{StaticResource DangerTextButton}"
                    Margin="0,8,0,0"
                    Clicked="OnLogoutClicked" />

            <Label Text="OpenNas — NAS 相册与文件管理"
                   Style="{StaticResource MicroCaption}"
                   HorizontalOptions="Center"
                   Margin="0,16,0,8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
