<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             x:Class="OpenNas.Views.ProfilePage"
             Title="我的">
    <ScrollView>
        <VerticalStackLayout Padding="8" Spacing="12">
            <controls:ConnectionBanner x:Name="ConnectionBanner" />

            <Border Padding="16" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="NAS 信息" FontSize="17" FontAttributes="Bold" />
                    <Label x:Name="ProfileNameLabel" FontSize="15" />
                    <Label x:Name="ProfileUrlLabel" FontSize="12" TextColor="Gray" />
                    <Label x:Name="LoginStateLabel" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <Button Text="连接与账号设置" Clicked="OnConnectionClicked" />
            <Button Text="重新登录" Clicked="OnReloginClicked" />
            <Button Text="退出登录" Clicked="OnLogoutClicked" TextColor="DarkRed" />

            <Label Text="OpenNas — NAS 相册与文件管理"
                   FontSize="11"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,16,0,8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
