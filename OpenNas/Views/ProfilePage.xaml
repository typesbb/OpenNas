<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             x:Class="OpenNas.Views.ProfilePage"
             Title="我的"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground}, Dark={StaticResource AppBackgroundDark}}">
    <Grid RowDefinitions="Auto,*">
        <controls:PageTitleBar Grid.Row="0" Title="我的" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">
                <Border Style="{StaticResource CardBorder}">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="1" ColumnSpacing="8" Padding="0">
                        <Label x:Name="UsernameLabel" Grid.Row="0" Grid.Column="0"
                               FontSize="17" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                        <Button x:Name="SwitchButton" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                Text="切换" Style="{StaticResource SecondaryButton}"
                                FontSize="12" Padding="10,6" MinimumHeightRequest="32"
                                VerticalOptions="Center" Clicked="OnSwitchClicked" />
                        <Label x:Name="ConnectionDetailLabel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Style="{StaticResource Caption}" LineBreakMode="TailTruncation"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRowBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnConnectionClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="连接设置" VerticalOptions="Center" FontSize="15" />
                        <Label Grid.Column="1" Text="›" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRowBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackupSettingsClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="备份策略" VerticalOptions="Center" FontSize="15" />
                        <Label Grid.Column="1" Text="›" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRowBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="日志" VerticalOptions="Center" FontSize="15" />
                        <Label Grid.Column="1" Text="›" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRowBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearCacheClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="清理缓存" VerticalOptions="Center" FontSize="15" />
                        <Label x:Name="CacheSizeLabel"
                               Grid.Column="1"
                               Style="{StaticResource Caption}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingRowBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnThemeRowTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="外观" VerticalOptions="Center" FontSize="15" />
                        <Label x:Name="ThemeLabel" Grid.Column="1"
                               Style="{StaticResource Caption}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>
<Button Text="退出登录"
                        Style="{StaticResource DangerTextButton}"
                        Margin="0,8,0,0"
                        Clicked="OnLogoutClicked" />

                <Label Text="OpenNas — NAS 相册与文件管理"
                       Style="{StaticResource MicroCaption}"
                       HorizontalOptions="Center"
                       Margin="0,16,0,8" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
