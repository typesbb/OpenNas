<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.BackupSettingsPage"
             Title="备份策略"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground}, Dark={StaticResource AppBackgroundDark}}">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              Padding="4,8,8,4"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="4">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    Style="{StaticResource ToolbarIconButton}"
                    SemanticProperties.Hint="返回"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="备份策略"
                   FontFamily="OpenSansSemibold"
                   FontSize="18"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
        </Grid>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Switch x:Name="WifiOnlySwitch" Toggled="OnWifiOnlyToggled" VerticalOptions="Center" WidthRequest="52" HorizontalOptions="Start" />
                            <Label Grid.Column="1" Text="仅 Wi-Fi 时备份" VerticalOptions="Center" FontSize="15" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Switch x:Name="ConfirmDeleteSwitch" Toggled="OnConfirmDeleteToggled" VerticalOptions="Center" WidthRequest="52" HorizontalOptions="Start" />
                            <Label Grid.Column="1" Text="删除本地前需已确认风险" VerticalOptions="Center" FontSize="15" />
                        </Grid>
                        <Button Text="我已了解删除风险"
                                Style="{StaticResource OutlineButton}"
                                Clicked="OnAckDeleteRiskClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
