<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.PhotoViewerPage"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="None"
             BackgroundColor="Black">
    <Grid SafeAreaEdges="None">
        <Grid x:Name="DismissHost" SafeAreaEdges="None" />

        <!-- 页面级缩略图占位：只用 FromFile，盖在媒体层之上 -->
        <Image x:Name="ThumbnailPlaceholder"
               Aspect="AspectFit"
               InputTransparent="True"
               IsVisible="False"
               ZIndex="100"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <!-- 空白区域穿透到手势层；仅按钮可点 -->
        <Grid x:Name="ChromeLayer"
              SafeAreaEdges="None"
              ZIndex="30"
              InputTransparent="True"
              CascadeInputTransparent="False">
            <Grid VerticalOptions="Start"
                  Padding="8,0,8,0"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <ImageButton x:Name="BackButton"
                             Grid.Column="0"
                             Source="icon_back.png"
                             BackgroundColor="#44FFFFFF"
                             CornerRadius="22"
                             VerticalOptions="Center"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             Clicked="OnBackClicked" />
                <ImageButton x:Name="InfoButton"
                             Grid.Column="2"
                             Source="icon_info.png"
                             BackgroundColor="#44FFFFFF"
                             CornerRadius="22"
                             VerticalOptions="Center"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             Clicked="OnInfoClicked" />
            </Grid>

            <!-- 照片预览时底部旋转（视频用播放条上的旋转） -->
            <Button x:Name="PhotoRotateButton"
                    Text="↻"
                    FontSize="18"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,12,24"
                    Clicked="OnRotateClicked" />
        </Grid>

        <Border x:Name="DetailPanel"
                IsVisible="False"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="16,0,16,96"
                Padding="14,12"
                BackgroundColor="#CC000000"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="DetailTitleLabel"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           MaxLines="2" />
                    <Label x:Name="DetailSubtitleLabel"
                           TextColor="#CCFFFFFF"
                           FontSize="12"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                <BoxView x:Name="ActionBarDividerTop"
                         HeightRequest="1"
                         Color="#44FFFFFF"
                         HorizontalOptions="Fill" />
                <HorizontalStackLayout x:Name="ActionButtons"
                                       Spacing="8"
                                       HorizontalOptions="Center">
                    <Button x:Name="DownloadButton"
                            Text="下载"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Padding="16,8"
                            Clicked="OnDownloadClicked" />
                    <BoxView x:Name="ActionBarDivider"
                             WidthRequest="1"
                             HeightRequest="20"
                             Color="#66FFFFFF"
                             VerticalOptions="Center" />
                    <Button x:Name="ShareButton"
                            Text="分享"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Padding="16,8"
                            Clicked="OnShareClicked" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <Border x:Name="ExportProgressPanel"
                IsVisible="False"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="16,0,16,32"
                Padding="12,10"
                BackgroundColor="#CC000000"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="6">
                <Label x:Name="ExportStatusLabel"
                       Text="正在下载…"
                       TextColor="White"
                       FontSize="13" />
                <ProgressBar x:Name="ExportProgressBar"
                             Progress="0"
                             ProgressColor="White"
                             HeightRequest="4" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
