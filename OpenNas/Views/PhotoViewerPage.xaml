<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Views.PhotoViewerPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    <Grid>
        <Grid x:Name="DismissHost" />
        <ImageButton x:Name="BackButton"
                     Source="icon_back.png"
                     BackgroundColor="#44FFFFFF"
                     CornerRadius="22"
                     HorizontalOptions="Start"
                     VerticalOptions="Start"
                     Margin="8,44,0,0"
                     WidthRequest="44"
                     HeightRequest="44"
                     Padding="10"
                     Clicked="OnBackClicked" />
        <ImageButton x:Name="FullscreenButton"
                     Source="icon_fullscreen.png"
                     BackgroundColor="Transparent"
                     HorizontalOptions="End"
                     VerticalOptions="End"
                     Margin="0,0,12,24"
                     WidthRequest="44"
                     HeightRequest="44"
                     Padding="8"
                     Clicked="OnFullscreenClicked" />

        <Border x:Name="ActionBar"
                IsVisible="False"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="16,0,16,96"
                Padding="8,6"
                BackgroundColor="#CC000000"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="8">
                <Button x:Name="DownloadButton"
                        Text="下载"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Padding="16,8"
                        Clicked="OnDownloadClicked" />
                <BoxView WidthRequest="1"
                         HeightRequest="20"
                         Color="#66FFFFFF"
                         VerticalOptions="Center" />
                <Button x:Name="ShareButton"
                        Text="分享"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Padding="16,8"
                        Clicked="OnShareClicked" />
            </HorizontalStackLayout>
        </Border>

        <Border x:Name="ExportProgressPanel"
                IsVisible="False"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="16,0,16,32"
                Padding="12,10"
                BackgroundColor="#CC000000"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="6">
                <Label x:Name="ExportStatusLabel"
                       Text="正在下载…"
                       TextColor="White"
                       FontSize="13" />
                <ProgressBar x:Name="ExportProgressBar"
                             Progress="0"
                             ProgressColor="White"
                             HeightRequest="4" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
