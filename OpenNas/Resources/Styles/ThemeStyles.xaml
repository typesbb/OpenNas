<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- 卡片容器 -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="12" />
        </Setter>
    </Style>

    <!-- 输入框容器 -->
    <Style x:Key="InputBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="10" />
        </Setter>
    </Style>

    <!-- 文字层级 -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <Style x:Key="MicroCaption" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- 按钮变体 -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource BrandOnPrimary}, Dark={StaticResource AppBackgroundDark}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="DangerTextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Error}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- 设置行 -->
    <Style x:Key="SettingRowBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="10" />
        </Setter>
    </Style>

    <!-- 进度条 -->
    <Style x:Key="BrandProgressBar" TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}" />
        <Setter Property="HeightRequest" Value="6" />
    </Style>

    <Style x:Key="ThinProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource BrandProgressBar}">
        <Setter Property="HeightRequest" Value="3" />
    </Style>

    <!-- 队列行背景进度（整行从左向右填充，非底部细线） -->
    <Style x:Key="QueueRowFillProgressBar" TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource BrandPrimarySoft}, Dark={StaticResource BrandPrimarySoftDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- 功能标签 -->
    <Style x:Key="FeatureChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BrandPrimarySoft}, Dark={StaticResource BrandPrimarySoftDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <!-- 紧凑按钮 -->
    <Style x:Key="CompactPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="CompactSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="MinimumWidthRequest" Value="40" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="CompactOutlineButton" TargetType="Button" BasedOn="{StaticResource OutlineButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="IconCircleButton" TargetType="Button" BasedOn="{StaticResource CompactSecondaryButton}">
        <Setter Property="WidthRequest" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- 规则行 -->
    <Style x:Key="RuleRowBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

</ResourceDictionary>
