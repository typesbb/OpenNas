<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.DropdownMenuOverlay"
             IsVisible="False"
             InputTransparent="True"
             HorizontalOptions="Fill"
             VerticalOptions="Fill">
    <AbsoluteLayout x:Name="OverlayRoot"
                    InputTransparent="False"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">
        <Grid x:Name="DismissLayer"
              BackgroundColor="Transparent"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDismissTapped" />
            </Grid.GestureRecognizers>
        </Grid>

        <Border x:Name="MenuCard"
                AbsoluteLayout.LayoutBounds="0,0,Auto,Auto"
                AbsoluteLayout.LayoutFlags="None"
                MinimumWidthRequest="168"
                MaximumWidthRequest="260"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                StrokeThickness="0"
                Padding="4,6">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#33000000" Offset="0,4" Radius="12" Opacity="0.35" />
            </Border.Shadow>
            <VerticalStackLayout x:Name="ItemsStack" Spacing="0" />
        </Border>
    </AbsoluteLayout>
</ContentView>
