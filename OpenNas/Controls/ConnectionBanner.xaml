<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.ConnectionBanner"
             x:Name="Root">
    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
            StrokeThickness="1"
            Padding="12,8"
            Margin="8,4">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
                <Label x:Name="StatusLabel" FontSize="14" FontAttributes="Bold" />
                <Label x:Name="UrlLabel" FontSize="11" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
            <Button x:Name="SwitchButton" Text="切换" FontSize="12" Padding="12,4" Clicked="OnSwitchClicked" />
        </Grid>
    </Border>
</ContentView>
