<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.ConnectionBanner"
             x:Name="Root">
    <Border Style="{StaticResource CardBorder}" Padding="12,10" Margin="0">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <BoxView x:Name="StatusStripe"
                     WidthRequest="4"
                     VerticalOptions="Fill"
                     Color="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource Success}}"
                     Margin="-16,0,0,0" />
            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label x:Name="StatusLabel" FontSize="14" FontAttributes="Bold" />
                <Label x:Name="UrlLabel"
                       Style="{StaticResource MicroCaption}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
            <Button Grid.Column="2"
                    x:Name="SwitchButton"
                    Text="切换"
                    Style="{StaticResource SecondaryButton}"
                    FontSize="12"
                    Padding="12,4"
                    MinimumHeightRequest="36"
                    Clicked="OnSwitchClicked" />
        </Grid>
    </Border>
</ContentView>
