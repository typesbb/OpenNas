<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.LocalThumbnailView"
             x:Name="Root">
    <Border WidthRequest="40"
            HeightRequest="40"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>
        <Image x:Name="ThumbImage"
               Aspect="AspectFill"
               HeightRequest="40"
               WidthRequest="40" />
    </Border>
</ContentView>
