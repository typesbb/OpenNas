<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             xmlns:vm="clr-namespace:OpenNas.ViewModels"
             x:Class="OpenNas.Controls.BackupQueueRowView"
             x:DataType="vm:BackupQueueItemViewModel"
             IsVisible="{Binding IsActive}">
    <VerticalStackLayout Spacing="3">
        <Grid ColumnDefinitions="40,*,Auto"
              ColumnSpacing="10"
              Padding="0,2,0,0">
            <controls:LocalThumbnailView Grid.Column="0"
                                         ContentUri="{Binding ContentUri}" />
            <Label Grid.Column="1"
                   Text="{Binding FileName}"
                   FontSize="13"
                   LineBreakMode="TailTruncation"
                   VerticalOptions="Center" />
            <Label Grid.Column="2"
                   Text="{Binding StatusText}"
                   FontSize="11"
                   IsVisible="{Binding ShowStatusText}"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        </Grid>
        <ProgressBar Progress="{Binding RowProgress}"
                     Style="{StaticResource ThinProgressBar}"
                     IsVisible="{Binding ShowRowProgress}" />
    </VerticalStackLayout>
</ContentView>
