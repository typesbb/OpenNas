<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.AlbumSelectionCheckbox"
             x:Name="Root">
    <Border x:Name="Circle"
            WidthRequest="24"
            HeightRequest="24"
            StrokeThickness="2"
            Padding="0"
            BackgroundColor="Transparent"
            Stroke="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12" />
        </Border.StrokeShape>
        <Label x:Name="PartialMark"
               Text="−"
               IsVisible="False"
               FontSize="16"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}" />
        <Label x:Name="CheckMark"
               Text="✓"
               IsVisible="False"
               FontSize="14"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="White" />
    </Border>
</ContentView>
