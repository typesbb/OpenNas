<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.Controls.EmptyStateView"
             x:Name="Root">
    <VerticalStackLayout Padding="24" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
        <Label x:Name="TitleLabel" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
        <Label x:Name="MessageLabel" FontSize="13" TextColor="Gray" HorizontalTextAlignment="Center" />
    </VerticalStackLayout>
</ContentView>
