<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:foto="clr-namespace:NSynology.Foto;assembly=NSynology"
             xmlns:helpers="clr-namespace:OpenNas.Helpers"
             xmlns:controls="clr-namespace:OpenNas.Controls"
             x:Class="OpenNas.AlbumDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground}, Dark={StaticResource AppBackgroundDark}}">
    <Grid>
        <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0"
                  Padding="4,8,8,4"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="4">
                <Button Grid.Column="0"
                        Text="‹"
                        FontSize="28"
                        Style="{StaticResource ToolbarIconButton}"
                        SemanticProperties.Hint="返回"
                        Clicked="OnBackClicked" />
                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <Label x:Name="TitleLabel"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           HorizontalOptions="Center"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label x:Name="StatusLabel"
                           FontSize="12"
                           HorizontalOptions="Center"
                           IsVisible="False"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <HorizontalStackLayout x:Name="UploadProgressArea"
                                           IsVisible="False"
                                           HorizontalOptions="Center"
                                           Spacing="8"
                                           Margin="0,4,0,0">
                        <ProgressBar x:Name="UploadProgressBar"
                                     Progress="0"
                                     ProgressColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                                     WidthRequest="100"
                                     VerticalOptions="Center" />
                        <Button x:Name="CancelUploadButton"
                                Text="✕"
                                FontSize="14"
                                WidthRequest="32"
                                HeightRequest="32"
                                CornerRadius="16"
                                Padding="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Clicked="OnCancelUploadClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <Button x:Name="MoreButton"
                        Grid.Column="2"
                        Text="⋮"
                        Style="{StaticResource ToolbarIconButton}"
                        SemanticProperties.Hint="更多"
                        Clicked="OnMenuClicked" />
            </Grid>

            <Grid Grid.Row="1">
                <RefreshView x:Name="PhotosRefreshView"
                             RefreshColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}">
                    <CollectionView x:Name="PhotosView"
                                    IsGrouped="True"
                                    ItemSizingStrategy="MeasureFirstItem"
                                    ItemsLayout="VerticalGrid, 3"
                                    RemainingItemsThreshold="12"
                                    RemainingItemsThresholdReached="OnLoadMore"
                                    SelectionMode="None">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="helpers:PhotoDateGroup">
                                <Label Text="{Binding DateLabel}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="17"
                                       Margin="12,18,12,8"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="foto:Photo">
                                <Grid Margin="2"
                                      HeightRequest="112"
                                      BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPhotoTapped" />
                                    </Grid.GestureRecognizers>
                                    <controls:AlbumGridPhotoView Aspect="AspectFill" />
                                    <Label Text="▶"
                                           IsVisible="{Binding IsVideo}"
                                           FontSize="13"
                                           TextColor="White"
                                           BackgroundColor="#99000000"
                                           WidthRequest="28"
                                           HeightRequest="28"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>

                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimaryLight}}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                <Button x:Name="AddPhotoButton"
                        Text="+"
                        WidthRequest="56"
                        HeightRequest="56"
                        CornerRadius="28"
                        FontSize="28"
                        Padding="0"
                        Margin="0,0,20,24"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Style="{StaticResource PrimaryButton}"
                        SemanticProperties.Hint="添加照片"
                        Clicked="OnAddPhotoClicked" />
            </Grid>
        </Grid>

        <controls:DropdownMenuOverlay x:Name="Dropdown" ZIndex="99" />
    </Grid>
</ContentPage>