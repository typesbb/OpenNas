<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenNas.AlbumDetailPage"
             Title="AlbumDetailPage">
    <ScrollView VerticalOptions="FillAndExpand" Scrolled="ScrollView_Scrolled">
        <FlexLayout BindableLayout.ItemsSource="{Binding}" Wrap="Wrap" JustifyContent="Start">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" Margin="0" BackgroundColor="Transparent" BorderColor="Transparent">
                        <StackLayout>
                            <Image Aspect="AspectFill" HeightRequest="100" WidthRequest="100" HandlerChanged="OnImageHandlerChanged"/>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>
    </ScrollView>
</ContentPage>